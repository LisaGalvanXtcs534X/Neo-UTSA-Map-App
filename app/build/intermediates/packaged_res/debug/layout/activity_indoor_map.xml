<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/utsa_navy"
    android:orientation="vertical">

    <include layout="@layout/partial_header"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/utsa_navy"
        android:orientation="vertical"
        android:padding="12dp">

        <EditText
            android:id="@+id/in_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_search_pill"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="6dp"
            android:hint="@string/search_location"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="#111"
            android:textColorHint="#777"/>

        <TextView
            android:id="@+id/tv_building_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="STUDENT UNION - 2D MAP"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <com.neoutsa.mapapp.views.IndoorMapView
        android:id="@+id/indoor_map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <include layout="@layout/partial_bottom_nav"/>
</LinearLayout>
