<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/utsa_navy"
    android:orientation="vertical">

    <include layout="@layout/partial_header"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="SELECT CLASSES"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current schedule:"
                android:textColor="@color/utsa_navy"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/current_classes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#DDD"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add a new class:"
                android:textColor="@color/utsa_navy"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/in_course"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="@string/course_number_hint"
                android:textColor="#111"/>

            <EditText
                android:id="@+id/in_building"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/building_hint"
                android:textColor="#111"/>

            <EditText
                android:id="@+id/in_room"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/room_hint"
                android:textColor="#111"/>

            <EditText
                android:id="@+id/in_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/time_hint"
                android:textColor="#111"/>

            <EditText
                android:id="@+id/in_prof"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/professor_hint"
                android:textColor="#111"/>

            <EditText
                android:id="@+id/in_campus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/campus_hint"
                android:text="Main"
                android:textColor="#111"/>

            <Button
                android:id="@+id/btn_add"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_button"
                android:text="@string/save"
                android:textColor="@color/white"/>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/partial_bottom_nav"/>
</LinearLayout>
