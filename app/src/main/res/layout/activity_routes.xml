<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/utsa_navy"
    android:orientation="vertical">

    <include layout="@layout/partial_header"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_search_pill"
            android:padding="10dp"
            android:text="From: Devonshire Condominiums"
            android:textColor="#222"/>

        <Space android:layout_width="match_parent" android:layout_height="6dp"/>

        <EditText
            android:id="@+id/in_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_search_pill"
            android:drawableStart="@drawable/ic_pin"
            android:drawablePadding="6dp"
            android:hint="To: building name"
            android:imeOptions="actionGo"
            android:inputType="text"
            android:textColor="#111"
            android:textColorHint="#777"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.neoutsa.mapapp.views.RoutesMapView
            android:id="@+id/routes_map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <LinearLayout
            android:id="@+id/route_pills"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:padding="20dp"/>
    </FrameLayout>

    <include layout="@layout/partial_bottom_nav"/>
</LinearLayout>
